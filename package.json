{
  "name": "personal-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "dev": "set NEXT_DIST_DIR=.next-dev&& cmd /c \"npx -y node@22 node_modules\\next\\dist\\bin\\next dev\"",
    "dev:host": "next dev",
    "build": "set NEXT_DIST_DIR=.next-prod&& next build",
    "start": "set NEXT_DIST_DIR=.next-prod&& next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.12",
    "typescript": "5.7.2"
  }
}
