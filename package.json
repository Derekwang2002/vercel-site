{
  "name": "derek-hub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "dev": "set NEXT_DIST_DIR=.next-dev&& cmd /c \"npx -y node@22 node_modules\\next\\dist\\bin\\next dev\"",
    "dev:host": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:board": "node --import tsx --test lib/share-board/*.test.ts*",
    "test:series": "node --import tsx --test lib/post-series.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "katex": "^0.16.47",
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.20",
    "tsx": "^4.23.1",
    "typescript": "5.7.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
